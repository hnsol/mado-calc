{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server (port 8000)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Python HTTP Server (port 8080)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Node http-server (port 8000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8000"],
      "port": 8000
    }
  ]
}
